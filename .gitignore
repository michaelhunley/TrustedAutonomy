# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Nix
result
result-*

# direnv
.direnv/
.envrc

# macOS
.DS_Store

# Trusted Autonomy — runtime state (not committed)
.ta/staging/
.ta/goals/
.ta/store/
.ta/backups/
.ta/*.log
.ta/*.lock
.ta/change_summary.json
# Local operational data — machine-specific, not team-shared
.ta/audit.jsonl
.ta/consent.json
.ta/daemon.toml
.ta/*.pid
.ta/events.jsonl
.ta/events/
.ta/goal-history.jsonl
.ta/mcp_json_original
.ta/memory.rvf
.ta/memory/
.ta/plan_history.jsonl
.ta/pr_packages/
.ta/release-history.json
.ta/velocity-stats.jsonl
.ta/interactive_sessions/
# Plugin binaries are built artifacts — only config files (channel.toml) are committed
.ta/plugins/**/ta-channel-*
.ta/plugins/**/ta-plugin-*
# .ta/agents/, .ta/plugins/*/channel.toml, .ta/config.toml, .ta/workflow.toml — committed (team-shared)

# Claude Code local settings
.claude/

# Claude Flow runtime state
.claude-flow/
.swarm/
.hive-mind/
.mcp.json
