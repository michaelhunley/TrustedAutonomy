# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# Generic backup files (e.g. PLAN.md.bak created by cleanup scripts)
*.bak

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Nix
result
result-*

# direnv
.direnv/
.envrc

# macOS
.DS_Store

# ── Trusted Autonomy ──────────────────────────────────────────────────────────
#
# COMMITTED (team-shared config):
#   .ta/workflow.toml           — verify commands, git-submit settings
#   .ta/workflow.local.toml     — personal overrides (gitignored, see below)
#   .ta/config.toml             — project-level daemon config
#   .ta/config.local.toml       — personal overrides incl. [experimental] (gitignored)
#   .ta/agents/*.toml           — agent framework manifests
#   .ta/plugins/*/channel.toml  — channel plugin config
#   .ta/pr-template.md          — PR body template
#   .ta/release-history.json    — project release changelog
#   .ta/plan_history.jsonl      — timeline of plan phase completions
#   .ta/constitution.toml       — project behavioral invariants (vcs-ignore check, inject/restore rules)
#
# IGNORED (ephemeral / machine-specific):
#   .ta/staging/      — per-goal source copies (can be GBs with compiled target/)
#   .ta/goals/        — live goal state JSON (changes every run)
#   .ta/store/        — internal KV store
#   .ta/backups/      — CLAUDE.md backup during goal injection
#   .ta/memory/       — per-goal agent memory entries
#   .ta/events/       — structured event log shards (grows daily)
#   .ta/audit.jsonl   — local audit trail (aggregated by Central Daemon in v0.14.4)
#   .ta/goal-history.jsonl   — machine-specific timing, incomplete fields until v0.14.6
#   .ta/velocity-stats.jsonl — CPU/disk-dependent build timing, meaningless cross-machine
#   .ta/pr_packages/  — draft artifact packages
#   .ta/workflow-runs/ — governed workflow session state (run IDs, stage progress)
#   .ta/review/       — governed workflow reviewer verdicts (ephemeral per-run)
#   *.local.toml      — personal local overrides (never committed)
#

# Ephemeral state — never committed
.ta/staging/
.ta/goals/
.ta/store/
.ta/backups/
.ta/pr_packages/
.ta/interactive_sessions/
.ta/workflow-runs/
.ta/review/

# Ephemeral staging-root artifacts — written by agent during goal run, scoped to that run
# These must NOT be applied back to source (v0.15.14.7 enforces this in the overlay)
.ta-decisions.json

# Runtime / machine-specific files
.ta/*.log
.ta/*.lock      # includes apply.lock (written by ta draft apply, ephemeral per-machine)
.ta/*.pid
.ta/daemon.toml
.ta/change_summary.json
.ta/consent.json
.ta/mcp_json_original

# Local operational data — machine-specific, not team-shared
.ta/audit.jsonl
.ta/events.jsonl
.ta/events/
.ta/goal-history.jsonl
.ta/memory.rvf
.ta/memory/
.ta/velocity-stats.jsonl
.ta/operations.jsonl
.ta/heartbeats/

# Local override files — personal settings, never team-shared
.ta/*.local.toml
.ta/config.local.toml
.ta/workflow.local.toml

# Plugin binaries — built artifacts (only channel.toml config is committed)
.ta/plugins/**/ta-channel-*
.ta/plugins/**/ta-plugin-*

# Claude Code local settings
.claude/

# Claude Flow runtime state
.claude-flow/
.swarm/
.hive-mind/
.mcp.json
