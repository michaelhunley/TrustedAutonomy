<?xml version="1.0" encoding="UTF-8"?>
<!--
  Trusted Autonomy MSI installer definition.
  Built with WiX v4 (dotnet tool install -g wix -version "4.*").

  Usage (from workspace root):
    wix build apps/ta-cli/wix/main.wxs -d SourceDir=target\x86_64-pc-windows-msvc\release \
      -d Version=0.14.17.0 -d Platform=x64 -arch x64 -o ta.msi

  The installer:
  - Places ta.exe and ta-daemon.exe at %ProgramFiles%\TrustedAutonomy\
  - Adds the install directory to the system PATH
  - Registers an uninstaller in Add/Remove Programs
  - Creates a Start Menu shortcut "Trusted Autonomy Shell"

  Code signing: set WINDOWS_CODE_SIGN_CERT to sign automatically.
  If not set, the MSI is unsigned (functional but shows a warning on install).
-->

<?if $(var.Platform) = x64 ?>
<?define ProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
<?define ProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Trusted Autonomy"
    Version="$(var.Version)"
    Manufacturer="Trusted Autonomy"
    Language="1033"
    UpgradeCode="A8B3C4D5-E6F7-4A5B-9C8D-1E2F3A4B5C6D">

    <!-- Allow upgrade from prior versions -->
    <MajorUpgrade
      AllowSameVersionUpgrades="no"
      DowngradeErrorMessage="A newer version of Trusted Autonomy is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Product icon (optional — cargo-wix uses the binary's .ico if available) -->
    <!-- <Icon Id="ProductIcon" SourceFile="wix/ta.ico" /> -->
    <!-- <Property Id="ARPPRODUCTICON" Value="ProductIcon" /> -->

    <!-- Install directory -->
    <StandardDirectory Id="$(var.ProgramFilesFolder)">
      <Directory Id="INSTALLFOLDER" Name="TrustedAutonomy">
        <Component Id="MainExecutable" Guid="B1C2D3E4-F5A6-4B7C-8D9E-0F1A2B3C4D5E">
          <File
            Id="TaBinary"
            Name="ta.exe"
            Source="$(var.SourceDir)\ta.exe"
            KeyPath="yes" />

          <!-- Add install directory to PATH -->
          <Environment
            Id="PATH"
            Name="PATH"
            Value="[INSTALLFOLDER]"
            Permanent="no"
            Part="last"
            Action="set"
            System="yes" />
        </Component>

        <Component Id="DaemonExecutable" Guid="C2D3E4F5-A6B7-4C8D-9E0F-1A2B3C4D5E6F">
          <File
            Id="TaDaemonBinary"
            Name="ta-daemon.exe"
            Source="$(var.SourceDir)\ta-daemon.exe"
            KeyPath="yes" />
        </Component>

        <Component Id="TaStudioBat" Guid="B7C8D9E0-F1A2-4B3C-4D5E-6F7A8B9C0D1E">
          <File
            Id="TaStudioBatFile"
            Name="ta-studio.bat"
            Source="$(var.SourceDir)\ta-studio.bat"
            KeyPath="yes" />
        </Component>

        <!--
          Optional ProjFS feature registry marker.
          Component is referenced by the ProjFS Feature below.
          The actual DISM enable runs via the EnableClientProjFS CustomAction.
        -->
        <Component Id="EnableProjFS" Guid="D5E6F7A8-B9C0-4D1E-2F3A-4B5C6D7E8F9A">
          <RegistryValue
            Root="HKLM"
            Key="SOFTWARE\TrustedAutonomy\Features"
            Name="ProjFSEnabled"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>

        <Directory Id="DocsDir" Name="docs">
          <Component Id="UsageDoc" Guid="E4F5A6B7-C8D9-4E0F-1A2B-3C4D5E6F7A8B">
            <File
              Id="UsageHtml"
              Name="USAGE.html"
              Source="$(var.SourceDir)\USAGE.html"
              KeyPath="yes" />
          </Component>
        </Directory>

        <Directory Id="PluginsDir" Name="plugins">
          <Directory Id="VcsPluginsDir" Name="vcs">
            <Component Id="VcsPerforce" Guid="F5A6B7C8-D9E0-4F1A-2B3C-4D5E6F7A8B9C">
              <File
                Id="VcsPerforceScript"
                Name="vcs-perforce"
                Source="$(var.SourceDir)\plugins\vcs\vcs-perforce"
                KeyPath="yes" />
            </Component>
            <Component Id="VcsPerforceManifest" Guid="A6B7C8D9-E0F1-4A2B-3C4D-5E6F7A8B9C0D">
              <File
                Id="VcsPerforceToml"
                Name="vcs-perforce.toml"
                Source="$(var.SourceDir)\plugins\vcs\vcs-perforce.toml"
                KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Trusted Autonomy">
        <Component Id="StartMenuShortcut" Guid="D3E4F5A6-B7C8-4D9E-0F1A-2B3C4D5E6F7A">
          <Shortcut
            Id="TaShellShortcut"
            Name="Trusted Autonomy Shell"
            Description="Open the Trusted Autonomy interactive shell"
            Target="[INSTALLFOLDER]ta.exe"
            Arguments="shell"
            WorkingDirectory="INSTALLFOLDER" />
          <Shortcut
            Id="TaDocShortcut"
            Name="TA Documentation"
            Description="View Trusted Autonomy documentation"
            Target="[#UsageHtml]"
            WorkingDirectory="INSTALLFOLDER" />
          <Shortcut
            Id="TaStudioShortcut"
            Name="TA Studio"
            Description="Open TA Studio — the visual project browser and review dashboard"
            Target="[INSTALLFOLDER]ta-studio.bat"
            WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="CleanUpShortCut" On="uninstall" />
          <RegistryValue
            Root="HKCU"
            Key="Software\TrustedAutonomy"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Complete" Title="Trusted Autonomy" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="DaemonExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="UsageDoc" />
      <ComponentRef Id="VcsPerforce" />
      <ComponentRef Id="VcsPerforceManifest" />
      <ComponentRef Id="TaStudioBat" />
    </Feature>

    <!--
      Optional feature: Windows Projected File System (ProjFS).
      Enables near-instant, zero-disk-cost staging on NTFS by projecting
      source files on-demand. Requires Windows 10 version 1809 or later.

      When selected, runs Dism.exe to enable the Client-ProjFS optional feature.
      This requires administrator privileges and may require a reboot on older
      Windows builds (Windows 10 2004+ skips the reboot automatically).

      After enabling, set strategy = "projfs" in .ta/workflow.toml:
        [staging]
        strategy = "projfs"
    -->
    <Feature
      Id="ProjFS"
      Title="Enable fast virtual workspace (requires Windows 10 1809+)"
      Description="Enables Windows Projected File System (ProjFS) for near-instant, zero-disk-cost staging. Files are hydrated from source on demand — only files the agent actually reads are physically accessed."
      Level="2"
      AllowAdvertise="no">
      <ComponentRef Id="EnableProjFS" />
    </Feature>

    <!--
      Custom action: run DISM to enable Client-ProjFS when the ProjFS feature is selected.
      Dism.exe lives in %SystemRoot%\System32 (SystemFolder). Directory is required by WiX v4
      for ExeCommand-based custom actions.
      Condition: (&ProjFS = 3) means the feature is being installed (not already present).
    -->
    <CustomAction
      Id="EnableClientProjFS"
      Directory="SystemFolder"
      ExeCommand="Dism.exe /Online /Enable-Feature /FeatureName:Client-ProjFS /NoRestart"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="EnableClientProjFS" After="InstallFiles" Condition="(&amp;ProjFS = 3) AND NOT Installed" />
    </InstallExecuteSequence>

  </Package>
</Wix>
